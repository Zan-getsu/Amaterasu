+    return "/folder/" in link or "#F!" in link
+
+
+def get_mega_subfolder_handle(link: str) -> str | None:
+    if not link:
+        return None
+    parts = link.split("/folder/")
+    if len(parts) >= 3:
+        return parts[-1].split("#")[0].split("/")[0].split("?")[0]
+    parts = link.split("#F!")
+    if len(parts) >= 3:
+        return parts[-1].split("!")[0].split("/")[0].split("?")[0]
+    return None
+
+
