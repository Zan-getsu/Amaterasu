# Version control
.git
.gitignore

# Python caches and artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Test files (not needed in production image)
tests/
