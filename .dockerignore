# Dev tooling config (not needed at runtime)
.pre-commit-config.yaml
pyproject.toml

# Documentation
README.md
CHANGES.md
LICENSE

# CI/CD
.github/

# IDE/editor
.vscode/
.idea/
*.swp
*.swo

# OS artifacts
.DS_Store
Thumbs.db

# Runtime data (should be mounted as volumes, not baked into image)
downloads/
log.txt
rlog.txt
.amaterasu_secrets
.secrets

# User credentials (mount these as volumes)
config.py
token.pickle
rclone.conf
.netrc
accounts/
tokens/
cookies/
thumbnails/
rclone/
mediainfo/
list_drives.txt
shortener.txt
categories.txt
cookies.txt
cfg.zip

# Build artifacts
graphify-out/
.graphify_*
.agent*
